{
  "manifest_version": 3,
  "name": "EliteTorrent Link Decoder",
  "version": "1.0",

  "browser_specific_settings": {
    "gecko": {
      "id": "elitetorrent-link-decoder@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [],

  "host_permissions": [
    "*://*.elitetorrent.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.elitetorrent.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}